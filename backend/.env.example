# ── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── IA ─────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENROUTER_KEY=
# Modèles par usage (OpenRouter). Défauts dans config.py si non renseignés.
# EXTRACTION_MODEL : lecture/normalisation des CV ; SCORING_MODEL : 2e avis IA (score hybride)
EXTRACTION_MODEL=anthropic/claude-haiku-4.5
SCORING_MODEL=anthropic/claude-haiku-4.5
# Assistant intégré : clé OpenRouter dédiée (optionnelle, sinon OPENROUTER_KEY) + modèle
ASSISTANT_OPENROUTER_KEY=
ASSISTANT_MODEL=anthropic/claude-3.5-sonnet
# Fallback LLM si OpenRouter indisponible (ex. solde vide) — clé Mistral La Plateforme
MISTRAL_KEY=
MISTRAL_MODEL=mistral-small-latest

# ── Environnement ──────────────────────────────────────────
# "production" (défaut, durci : /docs coupé, HSTS, garde JWT) ou "dev"/"local"
APP_ENV=production

# ── Auth ───────────────────────────────────────────────────
# OBLIGATOIRE en prod : sans secret fort le backend REFUSE de démarrer.
#   JWT_SECRET=$(openssl rand -hex 32)
JWT_SECRET=change-me-in-production
FRONTEND_URL=https://git-alpha-hazel.vercel.app

# ── Email : SMTP Infomaniak (envoi transactionnel) ─────────
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USER=plateforme.grp-it@hbccp.fr
SMTP_PASSWORD=
SMTP_FROM=plateforme.grp-it@hbccp.fr
SMTP_FROM_NAME=UTI Group
# Destinataire pour scripts/test_smtp.py uniquement
SMTP_TEST_TO=

# Destinataire des notifications de support / contact
ADMIN_EMAIL=

# ── Stockage des fichiers (CV / avatars) ───────────────────
# "supabase" (défaut) = Supabase Storage | "s3" = OVH Object Storage
STORAGE_BACKEND=supabase
# Renseigner ci-dessous UNIQUEMENT si STORAGE_BACKEND=s3 :
S3_ENDPOINT_URL=https://s3.gra.io.cloud.ovh.net
S3_REGION=gra
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=uti-files
# Base URL publique des objets (souvent endpoint + nom du bucket)
S3_PUBLIC_BASE_URL=https://uti-files.s3.gra.io.cloud.ovh.net

# ── MIP RUM — tracing distribué (optionnel ; vide = middleware inactif) ────
# Endpoint d'ingestion MIP RUM et identifiant d'app (cf. console MIP RUM)
MIP_RUM_ENDPOINT=
MIP_RUM_APP_ID=
# Clé d'API de l'app (laisser vide si l'app n'a pas de clé)
MIP_RUM_API_KEY=
