# env.example — copier en .env (qui DOIT être dans .gitignore). Aucune valeur réelle ici.

# Bascule prod/dev : "prod" désactive /docs, active HSTS, masque les erreurs.
ENV=dev

# CORS — domaines explicites séparés par des virgules. Jamais "*" avec credentials.
ALLOWED_ORIGINS=https://app.exemple.com,https://exemple.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
# Clé publique anon : côté serveur ET front. NE PAS confondre avec service_role.
SUPABASE_ANON_KEY=
# service_role : pouvoir total, contourne RLS — SERVEUR UNIQUEMENT, jamais dans le front.
SUPABASE_SERVICE_ROLE_KEY=
# Secret JWT du projet (branche HS256). Laisser vide si vérification par JWKS.
SUPABASE_JWT_SECRET=
JWT_AUD=authenticated

# LLM
OPENAI_API_KEY=
# ou Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Monitoring
SENTRY_DSN=
